{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "src/**",
          "node_modules/.prisma/client/**",
          "node_modules/@prisma/client/**",
          "prisma/schema.prisma",
          "public/images/**",
          "public/attachement/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/main.ts"
    },
    {
      "src": "/images/(.*)",
      "dest": "src/main.ts"
    },
    {
      "src": "/produits/(.*)",
      "dest": "src/main.ts"
    },
    {
      "src": "/attachement/(.*)",
      "dest": "src/main.ts"
    },
    {
      "src": "/(.*)",
      "dest": "src/main.ts"
    }
  ]
}
