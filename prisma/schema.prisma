generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model abonnement {
  id                      Int                       @id @default(autoincrement())
  offre_id                Int?
  demande_id              Int?
  fournisseur_id          Int?
  zone_id                 Int?
  commercial_id           Int?
  mode_id                 Int?
  reference               String                    @db.VarChar(50)
  statut                  Boolean
  prix                    Float
  created                 DateTime                  @db.DateTime(0)
  expired                 DateTime?                 @db.DateTime(0)
  date_peiment            DateTime?                 @db.DateTime(0)
  duree_id                Int?
  remise                  Float
  currency_id             Int?
  commentaire             String?                   @db.VarChar(1000)
  type                    Boolean
  prix_admin              Float
  currency                currency?                 @relation(fields: [currency_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FK_351268BB38248176")
  offre                   offre?                    @relation(fields: [offre_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FK_351268BB4CC8505A")
  fournisseur             fournisseur?              @relation(fields: [fournisseur_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FK_351268BB670C757F")
  paiement                paiement?                 @relation(fields: [mode_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FK_351268BB77E5854A")
  commercial              commercial?               @relation(fields: [commercial_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FK_351268BB7854071C")
  demande_abonnement      demande_abonnement?       @relation(fields: [demande_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FK_351268BB80E95E18")
  zone_commercial         zone_commercial?          @relation(fields: [zone_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FK_351268BB9F2C3FAB")
  duree                   duree?                    @relation(fields: [duree_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FK_351268BBD13C140")
  abonnement_sous_secteur abonnement_sous_secteur[]

  @@index([currency_id], map: "IDX_351268BB38248176")
  @@index([offre_id], map: "IDX_351268BB4CC8505A")
  @@index([fournisseur_id], map: "IDX_351268BB670C757F")
  @@index([mode_id], map: "IDX_351268BB77E5854A")
  @@index([commercial_id], map: "IDX_351268BB7854071C")
  @@index([demande_id], map: "IDX_351268BB80E95E18")
  @@index([zone_id], map: "IDX_351268BB9F2C3FAB")
  @@index([duree_id], map: "IDX_351268BBD13C140")
}

